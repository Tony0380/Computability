{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Computability",
  "version": "0.2.2",
  "identifier": "io.github.tony0380.computability",
  "build": {
    "beforeDevCommand": "npm.cmd run dev",
    "beforeBuildCommand": "npm.cmd run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Computability",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 640,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": { "csp": "default-src 'self'; style-src 'self' 'unsafe-inline';" }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper", "silent": true },
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "languages": ["English", "Italian", "French", "German", "Spanish", "PortugueseBR"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQzNDY5MEFBODdBNEMwQkIKUldTN3dLU0hxcEJHUTVJUnp6dktmZUJkT3BEOVUyK3RZaTJ4djhEQWYxVHdJR0dYb0U4NVVWWTgK",
      "endpoints": ["https://github.com/Tony0380/Computability/releases/latest/download/latest.json"],
      "windows": { "installMode": "passive" }
    }
  }
}
