{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Computability",
  "version": "0.1.0",
  "identifier": "io.github.tony0380.computability",
  "build": {
    "beforeDevCommand": "npm.cmd run dev",
    "beforeBuildCommand": "npm.cmd run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{ "title": "Computability", "width": 1280, "height": 820, "minWidth": 900, "minHeight": 640 }],
    "security": { "csp": "default-src 'self'; style-src 'self' 'unsafe-inline';" }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper", "silent": true },
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": true,
        "languages": ["English", "Italian"]
      }
    }
  }
}
